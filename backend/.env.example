# GeoData Portal — Backend Environment Variables
# Copy this to .env and fill in your values

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://YOUR_USERNAME.github.io

# Maximum upload file size in MB
MAX_UPLOAD_MB=50

# Temp directory for ZIP extraction
TEMP_DIR=/tmp/geodata_portal
